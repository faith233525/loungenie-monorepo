{
  "require-dev": {
    "phpunit/phpunit": "^9.0",
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.0",
    "brain/monkey": "^2.6",
    "mockery/mockery": "^1.5",
    "phpunit/php-code-coverage": "^9.2",
    "yoast/phpunit-polyfills": "^1.1",
    "wp-cli/i18n-command": "^2.6"
  },
  "scripts": {
    "test": "vendor/bin/phpunit -c phpunit.xml",
    "test:fast": "vendor/bin/phpunit -c phpunit.xml --testsuite default",
    "test:unit": "vendor/bin/phpunit -c phpunit.xml --testsuite unit",
    "test:integration": "vendor/bin/phpunit -c phpunit.xml --testsuite integration",
    "test:performance": "vendor/bin/phpunit -c phpunit.xml --testsuite performance",
    "test:compatibility": "vendor/bin/phpunit -c phpunit.xml --testsuite compatibility",
    "test:coverage": "vendor/bin/phpunit -c phpunit.xml --coverage-clover=coverage/clover.xml --coverage-html=coverage/html --coverage-text=coverage/coverage.txt",
    "cs": "vendor/bin/phpcs -d memory_limit=512M -s .",
    "cbf": "vendor/bin/phpcbf -d memory_limit=512M ."
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
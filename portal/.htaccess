# PoolSafe Portal Cache Control
# Prevent caching of PHP files and dynamic content

<FilesMatch "\.(php|html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# Allow caching of static assets (JS, CSS, images) with versioning
<FilesMatch "\.(js|css|jpg|jpeg|png|gif|ico|svg|woff|woff2|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Explicit MIME type for CSS files (prevent text/html being served)
<FilesMatch "\.css$">
    Header set Content-Type "text/css; charset=UTF-8"
    Header set X-Content-Type-Options "nosniff"
</FilesMatch>

# Explicit MIME type for JavaScript files
<FilesMatch "\.js$">
    Header set Content-Type "application/javascript; charset=UTF-8"
    Header set X-Content-Type-Options "nosniff"
</FilesMatch>

# Disable ETags to prevent stale content serving
Header unset ETag
FileETag None

# Enable GZIP compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>


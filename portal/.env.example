# Environment configuration for LounGenie Portal
# Copy to .env and fill in values. Do NOT commit .env.

# Microsoft Graph (shared mailbox)
GRAPH_TENANT_ID="<tenant-guid>"
GRAPH_CLIENT_ID="<app-client-id>"
GRAPH_CLIENT_SECRET="<app-client-secret>"
LGP_SHARED_MAILBOX="shared@yourdomain.com"

# HubSpot
HUBSPOT_API_KEY="<private-app-access-token>"

# WordPress/Portal runtime
WP_ENV=production

# Pool-Safe-Portal environment variables
# Use these to configure Microsoft Graph shared mailbox integration safely.

# Azure AD App registration (Tenant-scoped)
LGP_AZURE_TENANT_ID=
LGP_AZURE_CLIENT_ID=
LGP_AZURE_CLIENT_SECRET=

# Shared mailbox to use for support
LGP_SHARED_MAILBOX=support@poolsafeinc.com

# Pipeline toggle: set to 'new' to enable Graph-based pipeline
# Supported values: new | legacy (or true/false/1/0)
LGP_EMAIL_PIPELINE=new

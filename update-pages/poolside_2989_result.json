title-md.wp-block-heading {\n  margin: 0;\n  font-size: clamp(2rem, 3.6vw, 3.2rem);\n  line-height: 1.02;\n  letter-spacing: -0.03em;\n  color: var(--lg-ink);\n}\n.lg9-title-sm,\n.lg9-title-sm.wp-block-heading {\n  margin: 0;\n  font-size: clamp(1.25rem, 2vw, 1.7rem);\n  line-height: 1.15;\n  color: var(--lg-ink);\n}\n.lg9-copy,\n.lg9-copy.wp-block-paragraph {\n  margin: 0;\n  font-size: clamp(1rem, 1.35vw, 1.16rem);\n  line-height: 1.7;\n  color: var(--lg-copy);\n  max-width: 62ch;\n}\n.lg9-copy strong {\n  color: var(--lg-ink);\n}\n.wp-block-buttons.lg9-cta-row {\n  margin-top: 28px;\n  gap: 14px;\n}\n.wp-block-button .wp-block-button__link.lg9-btn-primary,\n.wp-block-button .wp-block-button__link.lg9-btn-secondary {\n  padding: 15px 24px;\n  border-radius: 999px;\n  font-weight: 700;\n  text-decoration: none;\n  transition: transform .18s ease, box-shadow .18s ease, background-color .18s ease;\n}\n.wp-block-button .wp-block-button__link.lg9-btn-primary {\n  background: var(--lg-accent);\n  color: #fff;\n  box-shadow: 0 14px 34px rgba(13, 123, 114, 0.24);\n}\n.wp-block-button .wp-block-button__link.lg9-btn-primary:hover {\n  background: var(--lg-accent-dark);\n  transform: translateY(-1px);\n}\n.wp-block-button .wp-block-button__link.lg9-btn-secondary {\n  background: rgba(255,255,255,0.8);\n  color: var(--lg-ink);\n  border: 1px solid rgba(13, 36, 48, 0.16);\n}\n.wp-block-button .wp-block-button__link.lg9-btn-secondary:hover {\n  background: #fff;\n  transform: translateY(-1px);\n}\n.lg9-darkcta .lg9-kicker,\n.lg9-darkcta .lg9-title-md,\n.lg9-darkcta .lg9-copy,\n.lg9-darkcta .wp-block-heading,\n.lg9-darkcta .wp-block-paragraph {\n  color: #f5fbfc;\n}\n.lg9-darkcta .lg9-copy {\n  color: rgba(245, 251, 252, 0.82);\n}\n.lg9-card {\n  height: 100%;\n  padding: 28px;\n  border-radius: var(--lg-radius);\n  background: var(--lg-card);\n  border: 1px solid var(--lg-border);\n  box-shadow: var(--lg-shadow);\n}\n.lg9-card.lg9-card-soft {\n  background: linear-gradient(180deg, #ffffff 0%, #f7fbfc 100%);\n}\n.lg9-card .wp-block-heading,\n.lg9-card .wp-block-paragraph {\n  margin-top: 0;\n}\n.lg9-stat-row {\n  display: grid;\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n  gap: 14px;\n  margin-top: 26px;\n}\n.lg9-stat {\n  padding: 18px 20px;\n  background: rgba(255,255,255,0.8);\n  border: 1px solid rgba(13, 36, 48, 0.10);\n  border-radius: 18px;\n}\n.lg9-stat strong {\n  display: block;\n  margin-bottom: 6px;\n  font-size: 1.35rem;\n  color: var(--lg-ink);\n}\n.lg9-chip-row {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 10px;\n  margin-top: 18px;\n}\n.lg9-chip {\n  display: inline-flex;\n  align-items: center;\n  padding: 8px 14px;\n  border-radius: 999px;\n  background: #edf5f6;\n  color: #214251;\n  font-size: 0.92rem;\n  font-weight: 600;\n}\n.lg9-form-frame {\n  padding: 24px;\n  border-radius: var(--lg-radius);\n  background: #fff;\n  border: 1px solid var(--lg-border);\n  box-shadow: var(--lg-shadow);\n}\n.hs-form-wrapper form,\n.hs-form-wrapper .hs-form {\n  margin: 0;\n}\n.hs-form-wrapper input,\n.hs-form-wrapper textarea,\n.hs-form-wrapper select {\n  width: 100% !important;\n  border-radius: 14px !important;\n  border: 1px solid rgba(13, 36, 48, 0.16) !important;\n  padding: 13px 14px !important;\n  background: #fff !important;\n}\n.hs-form-wrapper .hs-button {\n  background: var(--lg-accent) !important;\n  color: #fff !important;\n  border: 0 !important;\n  border-radius: 999px !important;\n  padding: 15px 24px !important;\n  font-weight: 700 !important;\n}\n.hs-form-wrapper .hs-form-field {\n  margin-bottom: 16px !important;\n}\n@media (max-width: 900px) {\n  .lg9-stat-row { grid-template-columns: 1fr; }\n}\n<\/style>\n<!-- \/wp:html -->\n<!-- wp:kadence\/rowlayout {\"uniqueID\":\"lg-feat-hero\",\"columns\":1,\"className\":\"lg9-section lg9-hero\"} -->\n<div class=\"wp-block-kadence-rowlayout kb-row-layout-wrap kb-row-layout-id-lg-feat-hero lg9-section lg9-hero\"><div class=\"kt-row-column-wrap kt-has-1-columns kt-gutter-default kt-v-gutter-default kt-row-valign-top kt-row-layout-equal kt-tab-layout-row kt-m-colapse-left-to-right kt-mobile-layout-row kt-inner-column-height-default\">\n<div class=\"wp-block-kadence-column inner-column-1\"><div class=\"kt-inside-inner-col\">\n<!-- wp:group {\"className\":\"lg9-shell\",\"layout\":{\"type\":\"constrained\"}} --><div class=\"wp-block-group lg9-shell\"><!-- wp:paragraph {\"className\":\"lg9-kicker\"} --><p class=\"lg9-kicker\">Platform Features<\/p><!-- \/wp:paragraph --><!-- wp:heading {\"level\":1,\"className\":\"lg9-title-xl\"} --><h1 class=\"wp-block-heading lg9-title-xl\">Choose the right rollout for your premium seating operation<\/h1><!-- \/wp:heading --><!-- wp:paragraph {\"className\":\"lg9-copy\"} --><p class=\"lg9-copy\">LounGenie is structured in cumulative tiers so operators can start with the right guest experience and add service workflow or QR ordering when the property is ready.<\/p><!-- \/wp:paragraph --><!-- wp:buttons {\"className\":\"lg9-cta-row\"} --><div class=\"wp-block-buttons lg9-cta-row\"><!-- wp:button --><div class=\"wp-block-button\"><a class=\"wp-block-button__link wp-element-button lg9-btn-primary\" href=\"https:\/\/loungenie.com\/staging\/contact-loungenie\/\">Book a Property Demo<\/a><\/div><!-- \/wp:button --><!-- wp:button --><div class=\"wp-block-button\"><a class=\"wp-block-button__link wp-element-button lg9-btn-secondary\" href=\"https:\/\/loungenie.com\/staging\/cabana-installation-photos\/\">View Installation Gallery<\/a><\/div><!-- \/wp:button --><\/div><!-- \/wp:buttons --><\/div><!-- \/wp:group -->\n<\/div><\/div>\n<\/div><\/div>\n<!-- \/wp:kadence\/rowlayout -->\n\n<!-- wp:kadence\/rowlayout {\"uniqueID\":\"lg-feat-fit\",\"columns\":1,\"className\":\"lg9-section\"} -->\n<div class=\"wp-block-kadence-rowlayout kb-row-layout-wrap kb-row-layout-id-lg-feat-fit lg9-section\"><div class=\"kt-row-column-wrap kt-has-1-columns kt-gutter-default kt-v-gutter-default kt-row-valign-top kt-row-layout-equal kt-tab-layout-row kt-m-colapse-left-to-right kt-mobile-layout-row kt-inner-column-height-default\">\n<div class=\"wp-block-kadence-column inner-column-1\"><div class=\"kt-inside-inner-col\">\n<!-- wp:group {\"className\":\"lg9-shell\",\"layout\":{\"type\":\"constrained\"}} --><div class=\"wp-block-group lg9-shell\"><!-- wp:paragraph {\"className\":\"lg9-kicker\"} --><p class=\"lg9-kicker\">Decision Criteria<\/p><!-- \/wp:paragraph --><!-- wp:heading {\"level\":2,\"className\":\"lg9-title-md\"} --><h2 class=\"wp-block-heading lg9-title-md\">Start with the operating outcome you need to improve first.<\/h2><!-- \/wp:heading --><!-- wp:columns {\"className\":\"lg9-grid-3\"} --><div class=\"wp-block-columns lg9-grid-3\"><!-- wp:column --><div class=\"wp-block-column\"><!-- wp:group {\"className\":\"lg9-card lg9-card-soft\",\"layout\":{\"type\":\"default\"}} --><div class=\"wp-block-group lg9-card lg9-card-soft\"><!-- wp:heading {\"level\":3,\"className\":\"lg9-title-sm\"} --><h3 class=\"wp-block-heading lg9-title-sm\">Guest comfort<\/h3><!-- \/wp:heading --><!-- wp:paragraph {\"className\":\"lg9-copy\"} --><p class=\"lg9-copy\">If the goal is better seat value, guest satisfaction, and longer stays, start with the essentials built into Classic.<\/p><!-- \/wp:paragraph --><\/div><!-- \/wp:group --><\/div><!-- \/wp:column --><!-- wp:column --><div class=\"wp-block-column\"><!-- wp:group {\"className\":\"lg9-card lg9-card-soft\",\"layout\":{\"type\":\"default\"}} --><div class=\"wp-block-group lg9-card lg9-card-soft\"><!-- wp:heading {\"level\":3,\"className\":\"lg9-title-sm\"} --><h3 class=\"wp-block-heading lg9-title-sm\">Service workflow<\/h3><!-- \/wp:heading --><!-- wp:paragraph {\"className\":\"lg9-copy\"} --><p class=\"lg9-copy\">If the main issue is guest requests and staff response flow, Service+ adds the call button and alert path to the staff touchscreen monitor.<\/p><!-- \/wp:paragraph --><\/div><!-- \/wp:group --><\/div><!-- \/wp:column --><!-- wp:column --><div class=\"wp-block-column\"><!-- wp:group {\"className\":\"lg9-card lg9-card-soft\",\"layout\":{\"type\":\"default\"}} --><div class=\"wp-block-group lg9-card lg9-card-soft\"><!-- wp:heading {\"level\":3,\"className\":\"lg9-title-sm\"} --><h3 class=\"wp-block-heading lg9-title-sm\">F&amp;B conversion<\/h3><!-- \/wp:heading --><!-- wp:paragraph {\"className\":\"lg9-copy\"} --><p class=\"lg9-copy\">If the priority is shortening the path from intent to order, 2.0 adds QR ordering while keeping the full Service+ workflow in place.<\/p><!-- \/wp:paragraph --><\/div><!-- \/wp:group --><\/div><!-- \/wp:column --><\/div><!-- \/wp:columns --><\/div><!-- \/wp:group -->\n<\/div><\/div>\n<\/div><\/div>\n<!-- \/wp:kadence\/rowlayout -->\n\n<!-- wp:kadence\/rowlayout {\"uniqueID\":\"lg-feat-tiers\",\"columns\":1,\"className\":\"lg9-section lg9-soft\"} -->\n<div class=\"wp-block-kadence-rowlayout kb-row-layout-wrap kb-row-layout-id-lg-feat-tiers lg9-section lg9-soft\"><div class=\"kt-row-column-wrap kt-has-1-columns kt-gutter-default kt-v-gutter-default kt-row-valign-top kt-row-layout-equal kt-tab-layout-row kt-m-colapse-left-to-right kt-mobile-layout-row kt-inner-column-height-default\">\n<div class=\"wp-block-kadence-column inner-column-1\"><div class=\"kt-inside-inner-col\">\n<!-- wp:group {\"className\":\"lg9-shell\",\"layout\":{\"type\":\"constrained\"}} --><div class=\"wp-block-group lg9-shell\"><!-- wp:paragraph {\"className\":\"lg9-kicker\"} --><p class=\"lg9-kicker\">Configurations<\/p><!-- \/wp:paragraph --><!-- wp:heading {\"level\":2,\"className\":\"lg9-title-md\"} --><h2 class=\"wp-block-heading lg9-title-md\">Choose the rollout tier that fits your operation.<\/h2><!-- \/wp:heading --><!-- wp:columns {\"className\":\"lg9-grid-3\"} --><div class=\"wp-block-columns lg9-grid-3\"><!-- wp:column --><div class=\"wp-block-column\"><!-- wp:group {\"className\":\"lg9-card\",\"layout\":{\"type\":\"default\"}} --><div class=\"wp-block-group lg9-card\"><!-- wp:paragraph {\"className\":\"lg9-kicker\"} --><p class=\"lg9-kicker\">Classic<\/p><!-- \/wp:paragraph --><!-- wp:heading {\"level\":3,\"className\":\"lg9-title-sm\"} --><h3 class=\"wp-block-heading lg9-title-sm\">The premium-seat essentials<\/h3><!-- \/wp:heading --><!-- wp:paragraph {\"className\":\"lg9-copy\"} --><p class=\"lg9-copy\">Waterproof safe, solar USB charging, and a removable ice bucket for the premium seating foundation.<\/p><!-- \/wp:paragraph --><!-- wp:html --><div class=\"lg9-chip-row\"><span class=\"lg9-chip\">Waterproof safe<\/span><span class=\"lg9-chip\">Solar USB charging<\/span><span class=\"lg9-chip\">Removable ice bucket<\/span><\/div><!-- \/wp:html --><\/div><!-- \/wp:group --><\/div><!-- \/wp:column --><!-- wp:column --><div class=\"wp-block-column\"><!-- wp:group {\"className\":\"lg9-card\",\"layout\":{\"type\":\"default\"}} --><div class=\"wp-block-group lg9-card\"><!-- wp:paragraph {\"className\":\"lg9-kicker\"} --><p class=\"lg9-kicker\">Service+<\/p><!-- \/wp:paragraph --><!-- wp:heading {\"level\":3,\"className\":\"lg9-title-sm\"} --><h3 class=\"wp-block-heading lg9-title-sm\">Classic plus a staff-service workflow<\/h3><!-- \/wp:heading --><!-- wp:paragraph {\"className\":\"lg9-copy\"} --><p class=\"lg9-copy\">Adds a general service call button so the guest can request help and staff can see exactly which premium seat needs attention.<\/p><!-- \/wp:paragraph --><!-- wp:html --><div class=\"lg9-chip-row\"><span class=\"lg9-chip\">Everything in Classic<\/span><span class=\"lg9-chip\">Service call button<\/span><span class=\"lg9-chip\">Staff touchscreen alerts<\/span><\/div><!-- \/wp:html --><\/div><!-- \/wp:group --><\/div><!-- \/wp:column --><!-- wp:column --><div class=\"wp-block-column\"><!-- wp:group {\"className\":\"lg9-card\",\"layout\":{\"type\":\"default\"}} --><div class=\"wp-block-group lg9-card\"><!-- wp:paragraph {\"className\":\"lg9-kicker\"} --><p class=\"lg9-kicker\">2.0<\/p><!-- \/wp:paragraph --><!-- wp:heading {\"level\":3,\"className\":\"lg9-title-sm\"} --><h3 class=\"wp-block-heading lg9-title-sm\">Service+ plus QR ordering<\/h3><!-- \/wp:heading --><!-- wp:paragraph {\"className\":\"lg9-copy\"} --><p class=\"lg9-copy\">Adds QR ordering to the Service+ model so food-and-beverage intent can move faster while the service call workflow stays active.<\/p><!-- \/wp:paragraph --><!-- wp:html --><div class=\"lg9-chip-row\"><span class=\"lg9-chip\">Everything in Service+<\/span><span class=\"lg9-chip\">QR ordering<\/span><span class=\"lg9-chip\">Dedicated printer workflow<\/span><\/div><!-- \/wp:html --><\/div><!-- \/wp:group --><\/div><!-- \/wp:column --><\/div><!-- \/wp:columns --><\/div><!-- \/wp:group -->\n<\/div><\/div>\n<\/div><\/div>\n<!-- \/wp:kadence\/rowlayout -->\n\n<!-- wp:kadence\/rowlayout {\"uniqueID\":\"lg-feat-ops\",\"columns\":1,\"className\":\"lg9-section\"} -->\n<div class=\"wp-block-kadence-rowlayout kb-row-layout-wrap kb-row-layout-id-lg-feat-ops lg9-section\"><div class=\"kt-row-column-wrap kt-has-1-columns kt-gutter-default kt-v-gutter-default kt-row-valign-top kt-row-layout-equal kt-tab-layout-row kt-m-colapse-left-to-right kt-mobile-layout-row kt-inner-column-height-default\">\n<div class=\"wp-block-kadence-column inner-column-1\"><div class=\"kt-inside-inner-col\">\n<!-- wp:group {\"className\":\"lg9-shell\",\"layout\":{\"type\":\"constrained\"}} --><div class=\"wp-block-group lg9-shell\"><!-- wp:columns --><div class=\"wp-block-columns\"><!-- wp:column --><div class=\"wp-block-column\"><!-- wp:paragraph {\"className\":\"lg9-kicker\"} --><p class=\"lg9-kicker\">Operational Flow<\/p><!-- \/wp:paragraph --><!-- wp:heading {\"level\":2,\"className\":\"lg9-title-md\"} --><h2 class=\"wp-block-heading lg9-title-md\">Reduce friction for guests and staff.<\/h2><!-- \/wp:heading --><!-- wp:paragraph {\"className\":\"lg9-copy\"} --><p class=\"lg9-copy\">Service alerts route to the staff touchscreen monitor while QR orders print to a dedicated PoolSafe printer. Those are separate paths, which keeps the operational workflow clear.<\/p><!-- \/wp:paragraph --><\/div><!-- \/wp:column --><!-- wp:column --><div class=\"wp-block-column\"><!-- wp:group {\"className\":\"lg9-card\",\"layout\":{\"type\":\"default\"}} --><div class=\"wp-block-group lg9-card\"><!-- wp:heading {\"level\":3,\"className\":\"lg9-title-sm\"} --><h3 class=\"wp-block-heading lg9-title-sm\">Designed for operators<\/h3><!-- \/wp:heading --><!-- wp:html --><ul style=\"margin:16px 0 0;padding-left:20px;color:#466170;line-height:1.75;\"><li>Guest requests stay visible to staff without guesswork<\/li><li>Ordering stays close to the seat in 2.0<\/li><li>Each tier adds capability without replacing the previous one<\/li><\/ul><!-- \/wp:html --><\/div><!-- \/wp:group --><\/div><!-- \/wp:column --><\/div><!-- \/wp:columns --><\/div><!-- \/wp:group -->\n<\/div><\/div>\n<\/div><\/div>\n<!-- \/wp:kadence\/rowlayout -->\n\n<!-- wp:kadence\/rowlayout {\"uniqueID\":\"lg-feat-fitbyproperty\",\"columns\":1,\"className\":\"lg9-section lg9-soft\"} -->\n<div class=\"wp-block-kadence-rowlayout kb-row-layout-wrap kb-row-layout-id-lg-feat-fitbyproperty lg9-section lg9-soft\"><div class=\"kt-row-column-wrap kt-has-1-columns kt-gutter-default kt-v-gutter-default kt-row-valign-top kt-row-layout-equal kt-tab-layout-row kt-m-colapse-left-to-right kt-mobile-layout-row kt-inner-column-height-default\">\n<div class=\"wp-block-kadence-column inner-column-1\"><div class=\"kt-inside-inner-col\">\n<!-- wp:group {\"className\":\"lg9-shell\",\"layout\":{\"type\":\"constrained\"}} --><div class=\"wp-block-group lg9-shell\"><!-- wp:paragraph {\"className\":\"lg9-kicker\"} --><p class=\"lg9-kicker\">Where Each Tier Fits<\/p><!-- \/wp:paragraph --><!-- wp:heading {\"level\":2,\"className\":\"lg9-title-md\"} --><h2 class=\"wp-block-heading lg9-title-md\">Match the rollout to the seating zone, service model, and guest expectation.<\/h2><!-- \/wp:heading --><!-- wp:columns {\"className\":\"lg9-grid-3\"} --><div class=\"wp-block-columns lg9-grid-3\"><!-- wp:column --><div class=\"wp-block-column\"><!-- wp:group {\"className\":\"lg9-card lg9-card-soft\",\"layout\":{\"type\":\"default\"}} --><div class=\"wp-block-group lg9-card lg9-card-soft\"><!-- wp:heading {\"level\":3,\"className\":\"lg9-title-sm\"} --><h3 class=\"wp-block-heading lg9-title-sm\">Classic<\/h3><!-- \/wp:heading --><!-- wp:paragraph {\"className\":\"lg9-copy\"} --><p class=\"lg9-copy\">A fit for premium seating areas that need a stronger guest experience first, before adding service workflow or ordering.<\/p><!-- \/wp:paragraph --><\/div><!-- \/wp:group --><\/div><!-- \/wp:column --><!-- wp:column --><div class=\"wp-block-column\"><!-- wp:group {\"className\":\"lg9-card lg9-card-soft\",\"layout\":{\"type\":\"default\"}} --><div class=\"wp-block-group lg9-card lg9-card-soft\"><!-- wp:heading {\"level\":3,\"className\":\"lg9-title-sm\"} --><h3 class=\"wp-block-heading lg9-title-sm\">Service+<\/h3><!-- \/wp:heading --><!-- wp:paragraph {\"className\":\"lg9-copy\"} --><p class=\"lg9-copy\">A fit for operations that want fewer missed requests and clearer service visibility across cabanas or daybeds.<\/p><!-- \/wp:paragraph --><\/div><!-- \/wp:group --><\/div><!-- \/wp:column --><!-- wp:column --><div class=\"wp-block-column\"><!-- wp:group {\"className\":\"lg9-card lg9-card-soft\",\"layout\":{\"type\":\"default\"}} --><div class=\"wp-block-group lg9-card lg9-card-soft\"><!-- wp:heading {\"level\":3,\"className\":\"lg9-title-sm\"} --><h3 class=\"wp-block-heading lg9-title-sm\">2.0<\/h3><!-- \/wp:heading --><!-- wp:paragraph {\"className\":\"lg9-copy\"} --><p class=\"lg9-copy\">A fit for properties ready to capture more seat-side ordering activity without removing the underlying service call workflow.<\/p><!-- \/wp:paragraph --><\/div><!-- \/wp:group --><\/div><!-- \/wp:column --><\/div><!-- \/wp:columns --><\/div><!-- \/wp:group -->\n<\/div><\/div>\n<\/div><\/div>\n<!-- \/wp:kadence\/rowlayout -->\n\n<!-- wp:kadence\/rowlayout 
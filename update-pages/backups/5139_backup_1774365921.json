{"id":5139,"date":"2026-02-27T00:55:04","date_gmt":"2026-02-27T00:55:04","guid":{"rendered":"https:\/\/loungenie.com\/staging\/?page_id=5139"},"modified":"2026-03-24T12:57:08","modified_gmt":"2026-03-24T12:57:08","slug":"contact-loungenie","status":"publish","type":"page","link":"https:\/\/loungenie.com\/staging\/contact-loungenie\/","title":{"rendered":"Contact LounGenie | Request a Demo for Your Property"},"content":{"rendered":"\n<div class=\"wp-block-cover is-dark lg9-page-hero\" style=\"padding-top:84px;padding-right:24px;padding-bottom:84px;padding-left:24px;min-height:500px;aspect-ratio:unset;\"><span aria-hidden=\"true\" class=\"wp-block-cover__background has-black-background-color has-background-dim-52 has-background-dim\"><\/span><img decoding=\"async\" class=\"wp-block-cover__image-background\" alt=\"Contact LounGenie\" src=\"https:\/\/loungenie.com\/staging\/wp-content\/uploads\/2026\/03\/lg-contact-owc-cabana-scaled.jpg\" style=\"object-position:52% 30%\" data-object-fit=\"cover\" data-object-position=\"52% 30%\"\/><div class=\"wp-block-cover__inner-container is-layout-flow wp-block-cover-is-layout-flow\">\n<div class=\"wp-block-group has-global-padding is-layout-constrained wp-container-core-group-is-layout-a31aa551 wp-block-group-is-layout-constrained\">\n<h1 class=\"wp-block-heading\" style=\"font-size:clamp(31.609px, 1.976rem + ((1vw - 3.2px) * 2.541), 56px);line-height:1.02\">Contact LounGenie<\/h1>\n\n\n\n<p style=\"font-size:clamp(14px, 0.875rem + ((1vw - 3.2px) * 0.625), 20px);line-height:1.8\">Share your property goals and we will map the right deployment model for your cabanas and premium seating zones.<\/p>\n\n\n<div class=\"wp-block-buttons is-layout-flex wp-block-buttons-is-layout-flex\"><div class=\"wp-block-button\"><a class=\"wp-block-button__link wp-element-button\" href=\"mailto:info@poolsafeinc.com\">Email Our Team<\/a><\/div><\/div><\/div>\n<\/div><\/div>\n\n\n\n<div class=\"wp-block-group has-global-padding is-layout-constrained wp-
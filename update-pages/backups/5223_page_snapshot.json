  "title": {
    "rendered": "LounGenie Gallery | Cabana, Daybed &#038; Waterpark Installation Photos"
  },
  "content": {
    "rendered": "<div class=\"wp-block-kadence-rowlayout lg9-hero kadence-row\">\n<h1 class=\"lg-adv-heading lg9-title-md\">Installation imagery organized by venue style, not by property name.</h1>\n<p class=\"lg9-copy\" style=\"text-align:center;color:#cfeafe;margin-top:8px;\">A curated showcase of cabana, daybed and waterpark deployments — editorial, property-agnostic, and optimized for operator review.</p>\n<div class=\"wp-block-kadence-buttons lg9-cta-row\"></div>\n</div>\n<div class=\"wp-block-kadence-rowlayout lg9-section\">\n<div class=\"wp-block-kadence-rowlayout lg9-shell\">\n<div class=\"wp-block-kadence-rowlayout-column\" style=\"width:66%\">\n<h2 class=\"lg9-kicker\">Resort Cabanas</h2>\n<h3 class=\"lg9-title-md\">Premium seating environments and daybed-style installations.</h3>\n<p class=\"lg9-gallery-note\">Editorial grouping to highlight product moments without property naming.</p>\n</div>\n<div class=\"wp-block-kadence-rowlayout-column\" style=\"width:34%\">\n</div>\n</div>\n</div>\n<div class=\"wp-block-kadence-rowlayout lg9-section-soft\">\n<div class=\"wp-block-kadence-rowlayout lg9-shell\">\n<h2 class=\"lg9-kicker\">Waterpark Deployment</h2>\n<h3 class=\"lg9-title-md\">High-volume outdoor installs organized as one visual family.</h3>\n<p class=\"lg9-gallery-note\">Images show deployment patterns without identifying operators.</p>\n</div>\n</div>\n<div class=\"wp-block-kadence-rowlayout lg9-section\">\n<div class=\"wp-block-kadence-rowlayout lg9-shell\">\n<h2 class=\"lg9-kicker\">Amenity Details</h2>\n<h3 class=\"lg9-title-md\">Closer views of storage, charging, and in-cabana presentation.</h3>\n<p class=\"lg9-gallery-note\">Hardware and guest-use moments for operator review.</p>\n<div class=\"wp-block-kadence-buttons lg9-cta-row\"></div>\n</div>\n</div>\n",
    "protected": false
  },
  "excerpt": {
    "rendered": "<p>Browse LounGenie installation photos across cabanas, daybeds, and waterpark environments with detailed views of real premium seating deployments.</p>\n",
    "protected": false
  },

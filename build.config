[build-process]
version = "3.0.0"
name = "PoolSafe Portal"
build_date = "2025-12-09"
release_cycle = "LTS"

# Build targets
[targets]
wordpress = true
distribution = true
testing = true

# Quality gates
[quality]
min_php_version = "7.4"
min_wordpress_version = "5.9"
min_mysql_version = "5.7"
require_https = true
require_ssl_cert = true

# Testing requirements
[testing]
unit_test_coverage_minimum = 75
security_test_count_minimum = 80
integration_test_count_minimum = 30
code_coverage_minimum = 75

# Security checks
[security]
enable_xss_scanning = true
enable_sql_injection_scanning = true
enable_csrf_protection = true
enable_rate_limiting = true
enable_2fa = true
enable_api_signing = true

# Performance targets
[performance]
page_load_time_target_ms = 2000
api_response_time_target_ms = 200
cache_hit_rate_target = 85
concurrent_users_target = 100

# File configuration
[files]
critical_files = [
    "wp-poolsafe-portal.php",
    "includes/class-psp-2fa.php",
    "includes/class-psp-csrf-protection.php",
    "includes/class-psp-request-signer.php",
    "includes/class-psp-security-headers.php",
    "includes/class-psp-ip-whitelist.php",
    "includes/class-psp-rate-limiter.php"
]

documentation_files = [
    "readme.txt",
    "USER_GUIDE.md",
    "DEVELOPER_GUIDE_v3.md",
    "API_DOCUMENTATION.md",
    "DEPLOYMENT_GUIDE_v3.md",
    "TROUBLESHOOTING_FAQ.md",
    "DOCUMENTATION_INDEX_v3.md",
    "QUICK_START.md"
]

directories = [
    "admin",
    "assets",
    "css",
    "includes",
    "js",
    "languages",
    "public",
    "templates",
    "views"
]

# Distribution
[distribution]
archive_format = "zip"
create_checksum = true
checksum_algorithm = "sha256"
create_release_notes = true
create_install_script = true
create_verification_script = true

# Deployment
[deployment]
backup_before_install = true
backup_database = true
backup_files = true
run_migrations = true
run_integrity_checks = true
clear_cache_on_activate = true

# Documentation
[documentation]
include_readme = true
include_install_instructions = true
include_api_docs = true
include_developer_guide = true
include_user_guide = true
include_troubleshooting = true

# Versioning
[versioning]
semantic_versioning = true
version_format = "MAJOR.MINOR.PATCH"
current_version = "3.0.0"
stable_branch = "main"
development_branch = "develop"

# Licensing
[licensing]
license_type = "Commercial"
require_activation = false
check_updates = true
update_url = "https://poolsafe.com/api/updates"

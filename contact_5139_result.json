eading --><!-- wp:paragraph {\"className\":\"lg9-copy\"} --><p class=\"lg9-copy\">Service efficiency objectives, guest experience issues, and the commercial outcomes you want from premium seating.<\/p><!-- \/wp:paragraph --><\/div><!-- \/wp:group --><\/div><!-- \/wp:column --><\/div><!-- \/wp:columns --><\/div><!-- \/wp:group -->\n<\/div><\/div>\n<\/div><\/div>\n<!-- \/wp:kadence\/rowlayout -->\n\n<!-- wp:kadence\/rowlayout {\"uniqueID\":\"lg-contact-next\",\"columns\":1,\"className\":\"lg9-section lg9-soft\"} -->\n<div class=\"wp-block-kadence-rowlayout kb-row-layout-wrap kb-row-layout-id-lg-contact-next lg9-section lg9-soft\"><div class=\"kt-row-column-wrap kt-has-1-columns kt-gutter-default kt-v-gutter-default kt-row-valign-top kt-row-layout-equal kt-tab-layout-row kt-m-colapse-left-to-right kt-mobile-layout-row kt-inner-column-height-default\">\n<div class=\"wp-block-kadence-column inner-column-1\"><div class=\"kt-inside-inner-col\">\n<!-- wp:group {\"className\":\"lg9-shell\",\"layout\":{\"type\":\"constrained\"}} --><div class=\"wp-block-group lg9-shell\"><!-- wp:group {\"className\":\"lg9-card lg9-card-soft\",\"layout\":{\"type\":\"default\"}} --><div class=\"wp-block-group lg9-card lg9-card-soft\"><!-- wp:paragraph {\"className\":\"lg9-kicker\"} --><p class=\"lg9-kicker\">What Happens Next<\/p><!-- \/wp:paragraph --><!-- wp:heading {\"level\":2,\"className\":\"lg9-title-md\"} --><h2 class=\"wp-block-heading lg9-title-md\">A response built around operational fit.<\/h2><!-- \/wp:heading --><!-- wp:paragraph {\"className\":\"lg9-copy\"} --><p class=\"lg9-copy\">After you submit, our team reviews your property context and follows up with a recommended deployment path focused on guest-flow impact, operator practicality, and rollout fit.<\/p><!-- \/wp:paragraph --><\/div><!-- \/wp:group --><\/div><!-- \/wp:group -->\n<\/div><\/div>\n<\/div><\/div>\n<!-- \/wp:kadence\/rowlayout -->\n\n<!-- wp:kadence\/rowlayout {\"uniqueID\":\"lg-contact-cta\",\"columns\":1,\"class
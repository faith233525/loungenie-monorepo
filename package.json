{
    "name": "poolsafe-portal",
    "version": "3.2.5",
    "description": "PoolSafe Portal - WordPress Plugin with REST API",
    "type": "module",
    "main": "dist/psp-portal.js",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "eslint src --ext .js",
        "format": "prettier --write src",
        "test": "vitest",
        "test:ui": "vitest --ui"
    },
    "keywords": [
        "wordpress",
        "plugin",
        "rest-api",
        "pool",
        "management"
    ],
    "author": "PoolSafe Team",
    "license": "GPL-2.0+",
    "devDependencies": {
        "@fullhuman/postcss-purgecss": "^5.0.0",
        "autoprefixer": "^10.4.16",
        "cssnano": "^6.0.2",
        "eslint": "^8.55.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.0.1",
        "postcss": "^8.4.32",
        "prettier": "^3.1.1",
        "rollup-plugin-visualizer": "^5.12.0",
        "terser": "^5.26.0",
        "vite": "^5.0.7",
        "vite-plugin-compression": "^0.5.1",
        "vitest": "^1.1.0"
    },
    "dependencies": {
        "axios": "^1.6.5"
    },
    "browserslist": [
        "last 2 versions",
        "> 1%",
        "not dead"
    ],
    "prettier": {
        "semi": true,
        "trailingComma": "es5",
        "singleQuote": true,
        "printWidth": 100,
        "tabWidth": 4
    },
    "engines": {
        "node": ">=16.0.0",
        "npm": ">=8.0.0"
    }
}
<div class="lg9">

<!-- HERO -->
<section class="lg9-hero">
  <div class="lg9-hero-bg"><!-- wp:image {"id":8767,"sizeSlug":"large","linkDestination":"none"} -->
<!-- /wp:image --></div>
  <div class="lg9-hero-overlay"></div>
  <div class="lg9-hero-inner">
    <div class="lg9-shell">
      <div class="lg9-grid-2" style="align-items:center;">
        <div>
          <p class="lg9-kicker">Smart Cabana System — Zero Upfront Cost</p>
          <h1 class="lg9-title" style="color:#fff;margin:8px 0 18px;max-width:760px;line-height:1.2;">Turn Premium Seating Into A Revenue Engine, At $0 Upfront</h1>
          <p class="lg9-hero-lead" style="color:rgba(255,255,255,.92);margin:0 0 28px;line-height:1.6;">The LounGenie turns cabanas, daybeds, and premium seating into revenue-producing guest environments with QR ordering, a waterproof safe, solar-powered USB charging, and a removable ice bucket in one commercial-grade unit. Hotels, resorts, waterparks, and cruise lines can launch with no upfront cost.</p>
          <div class="lg9-btns">
            <a class="lg9-btn-primary" href="https://www.loungenie.com/index.php/contact-loungenie/">Get Your Free Revenue Projection</a>
            <a class="lg9-btn-secondary" href="https://www.loungenie.com/index.php/poolside-amenity-unit/">Explore Features</a>
          </div>
          <div class="lg9-hero-trust">
            <span class="lg9-hero-trust-item">$0 Upfront</span>
            <span class="lg9-hero-trust-item">Revenue Share Model</span>
            <span class="lg9-hero-trust-item">Built in Canada</span>
          </div>
        </div>
        <div>
          <div class="lg9-stat-panel">
          <div class="lg9-media" style="aspect-ratio:4/3;margin-bottom:16px;"><!-- wp:image {"id":8768,"sizeSlug":"large","linkDestination":"none"} -->
<!-- /wp:image --></div>
          <div class="lg9-stat-big">30%+</div>
          <p style="margin:6px 0 0;color:#243447;font-weight:700;line-height:1.5;">Poolside F&amp;B uplift reported after operators add the LounGenie to premium seating.</p>
          <p style="margin:8px 0 0;color:#2f455c;font-size:13px;line-height:1.65;">Zero upfront cost &middot; Revenue share &middot; PoolSafe installs and services.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- PARTNER LOGO STRIP -->
<section class="lg9-section" style="background:#fff;">
  <div style="text-align:center;max-width:860px;margin:0 auto 26px;padding:0 24px;">
    <p class="lg9-kicker">Trusted By Hospitality Leaders</p>
    <h2 class="lg9-title-md" style="margin:10px 0 14px;line-height:1.4;">Used by top hotels, resorts, cruise lines, and waterparks worldwide.</h2>
  </div>
  <div class="lg9-marquee-wrap">
    <div class="lg9-marquee-track">
      <div class="lg9-marquee-inner">
